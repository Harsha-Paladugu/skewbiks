{
  "name": "skewbiks",
  "private": true,
  "version": "0.0.0",
  "description": "Skewbiks.com — static site (OO census, solver, Skewb trainer, algorithm reference) plus its build. Sources compile to js/sheet.js and js/trainer.js.",
  "scripts": {
    "build:sheet": "node tools/compile-sheet.mjs",
    "build:trainer": "npm run build:sheet && node build.mjs",
    "build": "npm run build:trainer && npm run stamp && npm run check",
    "watch:trainer": "node build.mjs --watch",
    "stamp": "node tools/stamp-assets.mjs",
    "check": "node tools/check-sheet.mjs",
    "check:fresh": "node tools/check-fresh.mjs",
    "test": "node tools/check-sheet.mjs",
    "test:engine": "node tools/test-engine.mjs",
    "test:trainer": "node tools/test-trainer.mjs",
    "test:solver": "node tools/test-solver.mjs",
    "test:space": "node tools/verify-space.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "esbuild": "^0.25.12"
  }
}
