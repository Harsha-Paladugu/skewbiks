rules_version = '2';

// Skewbiks.com — Firestore security rules (the REAL authorization boundary).
//
// These are versioned here so they can be reviewed, diffed, and deployed from
// source instead of pasted into the console. Deploy with:
//
//   firebase deploy --only firestore:rules
//
// Admin is driven by an `admins/{uid}` collection (not a hardcoded uid), so
// adding/removing admins needs no rules edit or redeploy. The OO page shows your
// account's user id when you're signed in (see SETUP.md). `adminEmails` in
// js/config.js only gates the admin UI client-side — these rules enforce writes.
//
// BOOTSTRAP: create the first `admins/{your-uid}` document in the Firebase
// console (console writes bypass rules) before relying on admin access; after
// that, existing admins can manage the collection. Deploy these rules only once
// that doc exists, or admin writes lock out until you create it.
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function isMod() {
      return isAdmin()
        || (request.auth != null
            && exists(/databases/$(database)/documents/moderators/$(request.auth.uid)));
    }

    // per-user data: solver prefs + trainer progress (own doc only)
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /solutions/{id} {
      allow read: if resource.data.status == 'approved'
        || isMod()
        || (request.auth != null && request.auth.uid == resource.data.uid);
      // Create: only a moderator may submit, and only their own pending solution.
      // The field set is whitelisted (no extra/oversized docs) and every field the
      // client writes (js/oo.js submit()) is type/size validated. State-index bounds
      // are [0, NSLOTS) where NSLOTS = 360*12*2187 = 9,447,840 (engine.js).
      // `notation` records which system the solution text is written in — the
      // client re-verifies in that notation ("R' L R L'" parses in both but
      // means different corners).
      // NOTE: the "max 2 approved solutions" cap is PER SCRAMBLE SIDE (each side
      // of a mirror pair — one census entry, the hold-24 class re-derived from
      // `classId` — keeps its own cap; the pair's two sides count separately as
      // of 2026-07-10). It can't be enforced here — rules can't count sibling
      // docs — so it's applied app-side in js/oo.js (submit form gating + the
      // moderator approval step).
      allow create: if isMod()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasOnly([
            'uid', 'status', 'createdAt', 'pairId', 'classId', 'partnerId',
            'scramble', 'solution', 'notation', 'moves', 'name', 'showName'])
        && request.resource.data.createdAt == request.time
        && request.resource.data.notation in ['wca', 'ns']
        && request.resource.data.moves is int
        && request.resource.data.moves >= 1 && request.resource.data.moves <= 15
        && request.resource.data.solution is string
        && request.resource.data.solution.size() > 0
        && request.resource.data.solution.size() < 300
        && request.resource.data.scramble is string
        && request.resource.data.scramble.size() > 0
        && request.resource.data.scramble.size() < 300
        && request.resource.data.name is string
        && request.resource.data.name.size() < 256
        && request.resource.data.showName is bool
        && request.resource.data.classId is int
        && request.resource.data.classId >= 0 && request.resource.data.classId < 9447840
        && request.resource.data.partnerId is int
        && request.resource.data.partnerId >= 0 && request.resource.data.partnerId < 9447840
        && request.resource.data.pairId is int
        && request.resource.data.pairId >= 0 && request.resource.data.pairId < 9447840;
      // Update: a moderator may only flip the review fields (status -> approved/
      // rejected, plus reviewedBy); an admin may edit more broadly if ever needed.
      // This stops a moderator account from rewriting submitted solution content.
      allow update: if isAdmin()
        || (isMod()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'reviewedBy'])
            && request.resource.data.status in ['approved', 'rejected']
            && request.resource.data.reviewedBy is string);
      // Delete stays admin-only ON PURPOSE: it is the documented recovery for
      // the racy approval cap (js/oo.js review()). Deleting an approved
      // solution leaves the derived meta/doneMap + meta/stats stale — the
      // Moderation tab's admin "Recompute solved bitmap" action rebuilds both
      // from the surviving approved docs (solution docs are the source of
      // truth; the meta docs are a cache).
      allow delete: if isAdmin();
    }

    // Derived caches (doneMap bitmap, stats counters) rebuilt from the approved
    // solution docs — public to read so signed-out browsing works; any moderator
    // may write since every write is a recomputation, not user data.
    match /meta/{doc} {
      allow read: if true;
      allow write: if isMod();
    }

    // Moderator roster: isMod() trusts membership here. Self-create is allowed
    // only when a matching invite doc exists for the signer's email (the invite
    // acceptance flow); admins manage the rest.
    match /moderators/{uid} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == uid);
      allow create: if isAdmin()
        || (request.auth != null && request.auth.uid == uid
            && exists(/databases/$(database)/documents/moderatorInvites/$(request.auth.token.email)));
      allow delete: if isAdmin();
    }

    // Pending moderator invites, keyed by invitee email; readable by the
    // invitee (to accept) and admins (to manage), created/revoked by admins.
    match /moderatorInvites/{email} {
      allow read: if isAdmin() || (request.auth != null && request.auth.token.email == email);
      allow create, delete: if isAdmin();
    }

    // admin allowlist: who isAdmin() trusts. Bootstrap the first entry via the
    // console; thereafter only existing admins can grant/revoke admin.
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if isAdmin();
    }
  }
}
